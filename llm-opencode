#!/bin/bash
#
# llm-opencode — Launch OpenCode with auto-synced llm-server config
#
# Detects the running llm-server, syncs the model name and context size
# into OpenCode's config, then launches OpenCode.
#
# Usage:
#   llm-opencode              # Sync + launch (default port 8081)
#   llm-opencode --port 8082  # Use custom port
#   llm-opencode --sync-only  # Just sync config, don't launch
#   llm-opencode -h|--help    # Show this help
#
# Install:
#   ./install.sh              # Installs to ~/.local/bin/llm-opencode
#

set -euo pipefail

PORT=8081
SYNC_ONLY=0

# Parse args (pass unknown args through to opencode)
OPENCODE_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --port)      PORT="$2"; shift 2 ;;
        --sync-only) SYNC_ONLY=1; shift ;;
        -h|--help)   sed -n '3,/^$/s/^# \?//p' "$0"; exit 0 ;;
        *)           OPENCODE_ARGS+=("$1"); shift ;;
    esac
done

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/opencode.json"
[[ ! -f "$CONFIG_FILE" ]] && CONFIG_FILE="$HOME/.opencode.json"

# ── Sync with running server ──
MODELS_URL="http://localhost:${PORT}/v1/models"
SLOTS_URL="http://localhost:${PORT}/slots"

MODEL_ID=$(curl -sf --max-time 3 "$MODELS_URL" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d['data'][0]['id'])
except:
    pass
" 2>/dev/null) || true

if [[ -n "$MODEL_ID" && -f "$CONFIG_FILE" ]]; then
    # Get context size from slots endpoint
    SERVER_CTX=$(curl -sf --max-time 3 "$SLOTS_URL" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d[0]['n_ctx'])
except:
    print('65536')
" 2>/dev/null) || true
    [[ -z "$SERVER_CTX" ]] && SERVER_CTX=65536

    # Safe limit: 90% of server context
    SAFE_CTX=$(( SERVER_CTX * 90 / 100 ))

    # Update config
    if command -v jq >/dev/null 2>&1; then
        TMP_FILE=$(mktemp)
        if jq --arg mid "$MODEL_ID" --argjson ctx "$SAFE_CTX" --argjson port "$PORT" \
           '.provider["llama-cpp"].options.baseURL = "http://localhost:" + ($port|tostring) + "/v1" |
            .provider["llama-cpp"].models = {($mid): {"name": $mid, "limit": {"context": $ctx, "output": 16384}}} |
            .model = "llama-cpp/" + $mid' \
           "$CONFIG_FILE" > "$TMP_FILE" 2>/dev/null; then
            mv "$TMP_FILE" "$CONFIG_FILE"
            echo "Synced: $MODEL_ID (ctx=${SAFE_CTX}, port=${PORT})"
        else
            rm -f "$TMP_FILE"
            echo "Warning: failed to update config. Launching with existing config."
        fi
    else
        echo "Warning: jq not found — skipping config sync."
    fi
elif [[ -z "$MODEL_ID" ]]; then
    echo "No server detected on port ${PORT}. Launching OpenCode with existing config."
else
    echo "Warning: config file not found at $CONFIG_FILE"
fi

(( SYNC_ONLY )) && exit 0

# ── Launch OpenCode ──
OPENCODE_BIN=$(command -v opencode 2>/dev/null || echo "$HOME/.local/bin/opencode")

if [[ ! -x "$OPENCODE_BIN" ]]; then
    echo "Error: opencode not found."
    echo "  Install: curl -fsSL https://opencode.ai/install | bash"
    exit 1
fi

exec "$OPENCODE_BIN" "${OPENCODE_ARGS[@]+"${OPENCODE_ARGS[@]}"}"
